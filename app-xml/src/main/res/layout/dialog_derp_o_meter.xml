<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet_rounded"
    android:padding="24dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="250dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp">
        <ImageView
            android:id="@+id/dialogImageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Derp animal high res" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/dialogDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textColor="@color/color_card_title"
        android:textSize="14sp"
        app:fontFamily="sans-serif-medium"
        android:gravity="center" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Quão Derp é este animal?"
        android:textColor="@color/color_card_title"
        android:textSize="18sp"
        android:textStyle="bold"
        app:fontFamily="sans-serif-medium"
        android:gravity="center" />

    <com.google.android.material.slider.Slider
        android:id="@+id/dialogSlider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:valueFrom="0.0"
        android:valueTo="100.0"
        android:value="50.0"
        app:thumbColor="@color/color_slider_active"
        app:trackColorActive="@color/color_slider_active"
        app:trackColorInactive="@color/color_slider_inactive"
        android:stepSize="1.0" />

    <TextView
        android:id="@+id/dialogSliderText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nível de Derp: 50%"
        android:gravity="center"
        android:textSize="16sp"
        app:fontFamily="sans-serif-medium"
        android:textStyle="bold"
        android:textColor="@color/color_derp_text" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/dialogFavButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="24dp"
        android:text="Adicionar ao Hall of Fame"
        android:textColor="@color/color_button_text"
        app:fontFamily="sans-serif-medium"
        android:textStyle="bold"
        app:cornerRadius="24dp"
        app:backgroundTint="@color/color_button_bg"
        app:icon="@drawable/ic_star_white"
        app:iconTint="@android:color/white"
        app:iconGravity="textStart" />

</LinearLayout>
